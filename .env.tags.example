# Example .env file for azure-az-tag-manager.ps1
# Copy this file to .env.tags and fill in your values
# Do not commit the actual .env.tags file with secrets!

# Tag values that can be referenced in scripts
OWNER_EMAIL=your.email@company.com
COST_CENTER=IT-12345
PROJECT_NAME=MyProject
ENVIRONMENT=Production
TEAM_NAME=Infrastructure
DEPARTMENT=Engineering

# Sensitive values (will be masked in output)
SECRET_TAG_VALUE=sensitive-value-here
API_KEY=your-api-key-here
